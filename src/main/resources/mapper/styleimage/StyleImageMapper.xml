<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.strnd.api.styleimage.StyleImageMapper">

    <select id="findAllActive" resultType="com.strnd.api.styleimage.domain.StyleImage">
        <!-- 활성 스타일 이미지 전체 조회 (서비스 순, 정렬 순서 기준) -->
        SELECT
            IMAGE_ID, SERVICE_ID, IMAGE_URL, IMAGE_ALT, IS_ACTIVE, SORT_ORDER
        FROM mg_style_images
        WHERE IS_ACTIVE = 1
        ORDER BY SERVICE_ID ASC, SORT_ORDER ASC
    </select>

</mapper>